{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "agentreflex",
  "colors": {
    "primary": "#bc5430",
    "light": "#d98b5f",
    "dark": "#a3431f"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "light": "#f4efe6",
      "dark": "#1a1714"
    }
  },
  "fonts": {
    "heading": { "family": "Geist Mono" },
    "body": { "family": "Inter" }
  },
  "favicon": "/logo/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://agentreflex.dev"
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": ["introduction", "quickstart"]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/reflexes",
          "concepts/events",
          "concepts/decisions",
          "concepts/capability-matrix",
          "concepts/trust-model"
        ]
      },
      {
        "group": "Guides",
        "pages": ["guides/writing-a-reflex", "guides/distribution"]
      },
      {
        "group": "Reference",
        "pages": ["reference/cli", "reference/spec"]
      },
      {
        "group": "Community",
        "pages": ["contributing"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/agentreflex/agentreflex"
      }
    ],
    "primary": {
      "type": "button",
      "label": "agentreflex.dev",
      "href": "https://agentreflex.dev"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/agentreflex/agentreflex",
      "website": "https://agentreflex.dev"
    }
  }
}

{
  "name": "@agentreflex/core",
  "version": "0.1.1",
  "description": "The harness-agnostic event/decision model and reflex authoring API for agentreflex.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://agentreflex.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentreflex/agentreflex.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "shell-quote": "^1.8.2"
  },
  "devDependencies": {
    "@types/shell-quote": "^1.7.5"
  }
}

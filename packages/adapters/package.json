{
  "name": "@agentreflex/adapters",
  "version": "0.1.1",
  "description": "Per-harness hook adapters (Claude, Copilot, Cursor, Gemini, Codex) for agentreflex.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://agentreflex.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentreflex/agentreflex.git",
    "directory": "packages/adapters"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentreflex/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}

{
  "name": "agentreflex-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Give your AI agents reflexes — write the logic once, enforce it on every coding agent.",
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./reflexes/*\" build",
    "cli": "node packages/cli/dist/cli.js",
    "dev:setup": "node scripts/setup-dev.mjs",
    "registry:build": "node scripts/build-registry.mjs",
    "reflex:new": "node scripts/new-reflex.mjs",
    "reflex:dev": "node scripts/dev-reflex.mjs",
    "reflex:check": "node scripts/check-reflexes.mjs",
    "smoke:hook": "node scripts/smoke-hook.mjs",
    "dev": "pnpm -r dev",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
